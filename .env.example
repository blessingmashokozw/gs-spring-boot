# Environment variables template
# Copy this file to .env and fill in actual values
# NEVER commit .env file with real secrets to version control

# Database configuration
DATABASE_URL=jdbc:postgresql://localhost:5432/springboot
DATABASE_USERNAME=your_db_username
DATABASE_PASSWORD=your_db_password

# API Keys and Secrets
API_KEY=your_api_key_here
JWT_SECRET=your_jwt_secret_here_at_least_32_characters

# External service credentials
EXTERNAL_API_URL=https://api.example.com
EXTERNAL_API_TOKEN=your_external_api_token

# Monitoring and logging
LOG_LEVEL=INFO
SENTRY_DSN=your_sentry_dsn_if_using_sentry

# Security
CORS_ALLOWED_ORIGINS=https://yourdomain.com
SESSION_SECRET=your_session_secret_here

# Development/Testing
SPRING_PROFILES_ACTIVE=docker
